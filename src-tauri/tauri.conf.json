{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mdv",
  "version": "0.1.0",
  "identifier": "com.km7kumar.mdv",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
        {
          "label": "main",
          "title": "mdv",
          "visible": false,
          "width": 1440,
          "height": 960,
          "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**", "$DOCUMENT/**", "$DOWNLOAD/**", "$DESKTOP/**", "$PICTURE/**", "$VIDEO/**", "C:\\\\**", "/**"],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": {
        "default-src": "'self'",
        "base-uri": "'none'",
        "object-src": "'none'",
        "frame-ancestors": "'none'",
        "img-src": ["'self'", "data:", "blob:", "asset:", "https://asset.localhost", "http:", "https:"],
        "media-src": ["'self'", "data:", "blob:", "asset:", "https://asset.localhost", "http:", "https:"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "font-src": ["'self'", "data:"],
        "script-src": ["'self'"]
      },
      "devCsp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "targets": "all",
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    }
  }
}
