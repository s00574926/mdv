{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mdv",
  "version": "0.1.0",
  "identifier": "com.km7kumar.mdv",
  "build": {
    "beforeBuildCommand": "npm.cmd run build",
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "mdv",
        "width": 1440,
        "height": 960,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    }
  }
}
